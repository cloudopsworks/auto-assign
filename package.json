{
  "name": "auto-assign-action",
  "version": "3.0.2",
  "description": "Add reviewers to pull requests and assignees to pull requests or issues.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kentaro-m/auto-assign-action.git"
  },
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "package": "ncc build --source-map --license licenses.txt",
    "prepare": "husky install"
  },
  "author": "Kentaro Matsushita",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@actions/core": "^1.6.0",
    "@actions/github": "^9.0.0",
    "js-yaml": "^4.2.0",
    "lodash": "^4.17.20"
  },
  "devDependencies": {
    "@octokit/webhooks-types": "7.6.1",
    "@types/jest": "29.4.0",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "4.14.141",
    "@types/node": "^24.12.0",
    "@vercel/ncc": "0.38.4",
    "husky": "8.0.3",
    "jest": "29.7.0",
    "jest-circus": "29.7.0",
    "jest-mock": "29.7.0",
    "lint-staged": "13.3.0",
    "prettier": "3.8.1",
    "ts-jest": "29.4.6",
    "typescript": "5.8.3"
  },
  "lint-staged": {
    "*.ts": "prettier --write"
  }
}
